<?php

/**
 * @file
 * Hooks and helpers for the Achievements Learning module.
 */

use Drupal\comment\CommentInterface;
use Drupal\Core\Entity\EntityInterface;
use Drupal\Core\Render\Markup;
use Drupal\Component\Utility\Html;
use Drupal\node\NodeInterface;

/**
 * Implements hook_entity_insert().
 */
function achievements_learning_entity_insert(EntityInterface $entity): void {
  $forum_manager = \Drupal::service('achievements_learning.forum_manager');
  $achievement_manager = \Drupal::service('achievements_learning.achievement_manager');

  if ($entity instanceof NodeInterface && $entity->bundle() === 'forum' && $entity->isPublished()) {
    $uid = (int) $entity->getOwnerId();
    if ($forum_manager->isEligibleForumParticipant($entity->getOwner())) {
      $forum_manager->recordTopicCreated($uid, (int) $entity->id());
      $achievement_manager->recordForumTopic($uid, (int) $entity->id());
    }
  }

  if ($entity instanceof CommentInterface && $entity->bundle() === 'comment_forum' && $entity->isPublished()) {
    $uid = (int) $entity->getOwnerId();
    if ($forum_manager->isEligibleForumParticipant($entity->getOwner())) {
      $forum_manager->recordReplyCreated($uid, (int) $entity->id());
      $achievement_manager->recordForumReply($uid, (int) $entity->id());
    }
  }
}

/**
 * Implements hook_achievements_unlocked().
 */
function achievements_learning_achievements_unlocked($achievement, int $uid): void {
  \Drupal::service('achievements_learning.title_manager')->recomputeCurrentTitle($uid, $achievement);
}

/**
 * Implements hook_achievements_locked().
 */
function achievements_learning_achievements_locked($achievement, int $uid): void {
  \Drupal::service('achievements_learning.title_manager')->recomputeCurrentTitle($uid, $achievement);
}

/**
 * Implements hook_mail().
 */
function achievements_learning_mail(string $key, array &$message, array $params): void {
  $message['subject'] = $params['subject'] ?? 'Learning update';
  $message['body'][] = $params['body'] ?? '';
}

/**
 * Implements hook_preprocess_comment().
 */
function achievements_learning_preprocess_comment(array &$variables): void {
  if (empty($variables['comment']) || !$variables['comment'] instanceof CommentInterface || $variables['comment']->bundle() !== 'comment_forum') {
    return;
  }

  $title_markup = _achievements_learning_build_user_title_markup((int) $variables['comment']->getOwnerId());
  if ($title_markup === '') {
    return;
  }

  $variables['achievements_learning_title'] = Markup::create($title_markup);
  if (!empty($variables['submitted'])) {
    $variables['submitted'] = Markup::create($variables['submitted'] . '<br>' . $title_markup);
  }
}

/**
 * Implements hook_preprocess_node().
 */
function achievements_learning_preprocess_node(array &$variables): void {
  if (empty($variables['node']) || !$variables['node'] instanceof NodeInterface || $variables['node']->bundle() !== 'forum') {
    return;
  }

  $title_markup = _achievements_learning_build_user_title_markup((int) $variables['node']->getOwnerId());
  if ($title_markup === '') {
    return;
  }

  $variables['achievements_learning_title'] = Markup::create($title_markup);
  if (!empty($variables['author_name'])) {
    $variables['author_name'] = Markup::create($variables['author_name'] . '<br>' . $title_markup);
  }
  elseif (!empty($variables['submitted'])) {
    $variables['submitted'] = Markup::create($variables['submitted'] . '<br>' . $title_markup);
  }
}

/**
 * Builds escaped title markup for a user if a current title exists.
 */
function _achievements_learning_build_user_title_markup(int $uid): string {
  if ($uid <= 0) {
    return '';
  }

  $title = \Drupal::service('achievements_learning.title_manager')->getCurrentTitleForUser($uid);
  if ($title === '') {
    return '';
  }

  return '<span class="achievements-learning-user-title">' . Html::escape($title) . '</span>';
}
